{
  "name": "costume-line-chart",
  "version": "1.0.0",
  "description": "A high-performance canvas-based line chart component for React with zoom, pan, and multi-chart synchronization",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "types/index.d.ts",
  "files": [
    "dist",
    "types",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "babel src --out-dir dist --copy-files",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist",
    "test": "echo 'Tests not yet configured'"
  },
  "peerDependencies": {
    "dayjs": ">=1.10.0",
    "lodash": ">=4.17.0",
    "react": ">=17.0.0"
  },
  "keywords": [
