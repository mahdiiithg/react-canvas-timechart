    "url": "git+https://github.com/mahdiiithg/costume-line-chart.git"
  },
  "bugs": {
    "url": "https://github.com/mahdiiithg/costume-line-chart/issues"
  },
  "homepage": "https://github.com/mahdiiithg/costume-line-chart#readme",
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5"
  }
}
